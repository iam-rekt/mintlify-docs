{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "RobinSwap",
  "description": "The operating manual for Robinhood Chain liquidity.",
  "seo": {
    "metatags": {
      "canonical": "https://docs.robinswap.finance"
    }
  },
  "colors": {
    "primary": "#4a700a",
    "light": "#d8ff81",
    "dark": "#4a700a"
  },
  "favicon": "/favicon-32x32.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Start here",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Use RobinSwap",
        "pages": ["guides/swap", "guides/liquidity", "guides/portfolio", "guides/points"]
      },
      {
        "group": "Reference",
        "pages": ["reference/contracts"]
      }
    ],
    "global": {
      "anchors": [
        { "anchor": "App", "href": "https://www.robinswap.finance", "icon": "arrow-up-right-from-square" },
        { "anchor": "Explore", "href": "https://www.robinswap.finance/#explore", "icon": "chart-line" }
      ]
    },
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Guides",
        "icon": "book",
        "pages": [
          "guides/swap",
          "guides/liquidity",
          "guides/portfolio"
        ]
      },
      {
        "group": "Reference",
        "icon": "code",
        "pages": [
          "reference/contracts"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      { "label": "Explore markets", "href": "https://www.robinswap.finance/#explore" }
    ],
    "primary": {
      "type": "button",
      "label": "Open RobinSwap",
      "href": "https://www.robinswap.finance"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  }
}
