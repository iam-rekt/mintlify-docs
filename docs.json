{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "RobinSwap",
  "description": "Plain-language guides for trading, providing liquidity, and tracking activity on Robinhood Chain.",
  "seo": {
    "metatags": {
      "canonical": "https://docs.robinswap.finance"
    }
  },
  "colors": {
    "primary": "#82C900",
    "light": "#B7FF2A",
    "dark": "#3F7200"
  },
  "background": {
    "color": {
      "light": "#F2F1E9",
      "dark": "#0B0D0A"
    }
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "heading": {
      "family": "Instrument Sans",
      "weight": 650
    },
    "body": {
      "family": "Instrument Sans",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicon-32x32.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "groups": [
      {
        "group": "Start here",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Use RobinSwap",
        "pages": ["guides/swap", "guides/liquidity", "guides/portfolio", "guides/points"]
      },
      {
        "group": "Reference",
        "pages": ["reference/contracts"]
      }
    ],
    "global": {
      "anchors": [
        { "anchor": "Open app", "href": "https://www.robinswap.finance", "icon": "arrow-up-right" },
        { "anchor": "Explore markets", "href": "https://www.robinswap.finance/#explore", "icon": "chart-no-axes-combined" }
      ]
    }
  },
  "navbar": {
    "links": [
      { "label": "Explore markets", "href": "https://www.robinswap.finance/#explore" }
    ],
    "primary": {
      "type": "button",
      "label": "Open RobinSwap",
      "href": "https://www.robinswap.finance"
    }
  },
  "search": {
    "prompt": "Search RobinSwap docs"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt"]
  }
}
